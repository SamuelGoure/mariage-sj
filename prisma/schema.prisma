generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Rsvp {
  id          Int      @id @default(autoincrement())
  firstName   String   @map("first_name") @db.VarChar(100)
  lastName    String   @map("last_name")  @db.VarChar(100)
  attending   Boolean
  guestCount  Int      @default(1) @map("guest_count")
  mealChoice  Json?    @map("meal_choice")
  allergies   String?  @db.Text
  message     String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  guest       Guest?   @relation(fields: [guestId], references: [id])
  guestId     Int?     @unique @map("guest_id")

  @@map("rsvp")
}

model Guest {
  id        Int         @id @default(autoincrement())
  name      String      @db.VarChar(200)
  phone     String?     @db.VarChar(30)
  address   String?     @db.VarChar(300)
  group     String?     @db.VarChar(100)
  token     String      @unique @db.VarChar(64)
  status    GuestStatus @default(PENDING)
  rsvp      Rsvp?
  createdAt DateTime    @default(now()) @map("created_at")

  @@map("guests")
}

enum GuestStatus {
  PENDING
  CONFIRMED
  DECLINED
}

model Gallery {
  id           Int           @id @default(autoincrement())
  url          String        @db.VarChar(500)
  uploadedBy   String?       @map("uploaded_by") @db.VarChar(100)
  status       GalleryStatus @default(PENDING)
  createdAt    DateTime      @default(now()) @map("created_at")

  @@map("gallery")
}

enum GalleryStatus {
  PENDING
  APPROVED
  REJECTED
}

model AdminUser {
  id           Int      @id @default(autoincrement())
  email        String   @unique @db.VarChar(200)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("admin_users")
}

model ContentSection {
  key       String   @id @db.VarChar(50)
  data      Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("content_sections")
}
